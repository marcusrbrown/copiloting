{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['github>marcusrbrown/renovate-config#v4'],
  constraints: {
    python: '3.14',
  },
  packageRules: [
    {
      matchDepNames: ['python'],
      allowedVersions: '<=3.14',
    },
  ],
  postUpgradeTasks: {
    commands: ['pnpm format', 'poetry lock'],
    executionMode: 'branch',
    fileFilters: ['pnpm-lock.yaml', 'poetry.lock'],
    installTools: {
      pnpm: {},
      python: {constraint: '3.14'},
      poetry: {},
    },
  },
}
